{
  "name": "ai-gym-trainer-backend",
  "version": "2.0.0",
  "description": "Complete backend for AI Gym Trainer – workout schedule, video recording, real-time form feedback, and Telegram Mini App",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "setup": "npm install && mkdir -p public uploads logs models",
    "clean": "rm -rf node_modules uploads/* logs/*",
    "docker:build": "docker build -t gym-trainer .",
    "docker:run": "docker run -p 3000:3000 -v $(pwd)/uploads:/app/uploads -v $(pwd)/logs:/app/logs gym-trainer"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "gym",
    "fitness",
    "workout",
    "exercise",
    "pose-detection",
    "mediapipe",
    "form-check",
    "telegram-mini-app",
    "video-recording",
    "ai-trainer"
  ],
  "author": "AI Gym Trainer Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/ai-gym-trainer"
  },
  "bugs": {
    "url": "https://github.com/yourusername/ai-gym-trainer/issues"
  },
  "homepage": "https://github.com/yourusername/ai-gym-trainer#readme"
}
