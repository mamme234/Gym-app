# ================================================================
#  .env – Environment Variables for AI Gym Trainer Backend
# ================================================================

# ─── Server ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Upload Limits ──────────────────────────────────────────────
MAX_FILE_SIZE=524288000        # 500MB in bytes
UPLOAD_DIR=./uploads
STATIC_DIR=./public

# ─── Security ────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
SESSION_SECRET=your-session-secret-change-this-in-production

# ─── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com

# ─── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_WINDOW=60000        # 1 minute
RATE_LIMIT_MAX=100             # requests per window

# ─── Database (Optional) ────────────────────────────────────────
# If using MongoDB, uncomment and set your connection string
# MONGODB_URI=mongodb://localhost:27017/gymtrainer
# REDIS_URL=redis://localhost:6379

# ─── MediaPipe ──────────────────────────────────────────────────
# Path to Python executable (if using Python for pose analysis)
PYTHON_PATH=python3
MODELS_DIR=./models

# ─── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=./logs/server.log

# ─── Telegram Bot (Optional) ────────────────────────────────────
# Get these from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=7908759482:AAGQZm6DfFCu2ghj8n-xsNZqX8wax0w7jgQ
# TELEGRAM_WEBHOOK_URL=https://gym-app-ten-alpha.vercel.app/

# ─── Feature Flags ──────────────────────────────────────────────
ENABLE_WEBSOCKET=true
ENABLE_VIDEO_UPLOAD=true
ENABLE_POSE_ANALYSIS=true
ENABLE_TELEGRAM_MODE=true
